{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RFkit GUI",
  "version": "0.1.0",
  "identifier": "org.slinghub.rfkit.gui",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "RFkit GUI",
        "width": 1060,
        "height": 720,
        "minWidth": 760,
        "minHeight": 560,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "shortDescription": "RapidFire-MS processing with RFkit",
    "category": "Science"
  }
}
